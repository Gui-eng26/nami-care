# Copie este arquivo para .env.local e preencha com os valores do projeto
# Supabase "nami-care" (Dashboard > Project Settings > API).
# .env.local está no .gitignore — NUNCA versione chaves.

# Usadas pelo app (Vite expõe ao navegador apenas variáveis com prefixo VITE_)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key

# Usada APENAS pelo seed (scripts/seed.js). Ignora RLS — jamais expor no frontend.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
